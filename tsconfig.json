{
  "compilerOptions": {
    /* Project structure */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Module system */
    "module": "commonjs",
    "target": "es2020",

    /* Interop (fixes your express import issue) */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* Strictness & safety */
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Dev experience */
    "resolveJsonModule": true,
    "sourceMap": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}