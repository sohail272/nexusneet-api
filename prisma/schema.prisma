generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Question {
  id           String   @id @default(uuid())
  questionText String
  explanation  String?
  createdAt    DateTime @default(now())

  options      Option[]
}

model Option {
  id         String   @id @default(uuid())
  text       String
  isCorrect  Boolean  @default(false)

  question   Question @relation(fields: [questionId], references: [id])
  questionId String
}